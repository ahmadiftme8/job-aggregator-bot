# ==============================================================================
#  .env.example  —  Job Aggregator Bot v2
# ==============================================================================
#  1. Copy this file:  cp .env.example .env
#  2. Fill in your real values below
#  3. NEVER commit .env to Git  (it's in .gitignore)
#
#  For GitHub Actions → add each variable as a Repository Secret:
#  Repo → Settings → Secrets and variables → Actions → New repository secret
# ==============================================================================

# ── Telegram ──────────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram  (/newbot)
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"

# Your personal Telegram User ID or the Chat ID of a group/channel.
# To get your User ID: message @userinfobot on Telegram.
# For channels, the ID starts with -100...
# Format: 123456789  or  -1001234567890
TELEGRAM_CHAT_ID="your_telegram_chat_id_here"

GROQ_API_KEY="paste_your_new_key_here"
# ── Google Sheets Credentials ─────────────────────────────────────────────────
# The Base64-encoded content of your Google service account JSON key file.
#
# How to encode your credentials file:
#   macOS/Linux: base64 -i credentials.json | tr -d '\n'
#   Windows PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("credentials.json"))
#
# Paste the ENTIRE resulting Base64 string here (it will be very long — that's normal).
GOOGLE_SHEET_CREDENTIALS_JSON="your_base64_encoded_google_credentials_json_here"

# The ID of your Google Sheet (found in the URL of your spreadsheet).
# URL format: https://docs.google.com/spreadsheets/d/<THIS_IS_YOUR_ID>/edit
# Example: 1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms
GOOGLE_SHEET_ID="your_google_sheet_id_here"

# ── Bot Behaviour ─────────────────────────────────────────────────────────────
# How many days old a job can be before it's silently ignored (default: 14)
MAX_JOB_AGE_DAYS="14"

# Minimum match score (1–10) needed to trigger a Telegram alert (default: 5)
# Raise to 7 if you're getting too many alerts; lower to 4 if too few
MIN_SCORE_TO_ALERT="5"

# Set "true" to send a summary message after each run (good for monitoring)
SEND_RUN_SUMMARY="false"

# ── Debug / Development ───────────────────────────────────────────────────────
# Set "true" to:
#   • Print ALL fetched job titles with their scores
#   • Show exactly why each job matched or was filtered out
#   • SKIP sending real Telegram messages (safe dry run)
# Always set back to "false" before pushing to GitHub!
DEBUG_MODE="false"
